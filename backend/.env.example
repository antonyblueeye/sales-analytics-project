# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/meetalfred_db

# Anthropic Claude API key (get from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override model (default: claude-haiku-4-5)
# ANTHROPIC_MODEL=claude-haiku-4-5

# MeetAlfred auto-sync interval in minutes (default: 1440 = once per day)
# SYNC_INTERVAL_MINUTES=1440
# ENABLE_SCHEDULED_BACKUP=false
